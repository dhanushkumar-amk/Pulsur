# --- RUST & BUILD ---
target/
**/*.rs.bk
Cargo.lock (if you want lock-free, but here we track it)
!Cargo.lock

# --- SYSTEM & INTERNAL (IGNORE CONTENTS) ---
internal/audits/
internal/build-artifacts/
internal/test-results/
internal/temp-configs/
internal/logs/
internal/results/
internal/*.log
internal/*.txt

# --- NODE / JS ---
node_modules/
dist/
.next/
out/
build/
.npm
packages/@pulsur/**/bin/
packages/@pulsur/http-server/binary-path.json
npm-debug.log*

# --- SECRETS & CONFIG ---
.env*
!.env.example
certs/*.pem
!certs/.gitkeep

# --- IDE & SYSTEM ---
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# --- PLAYGROUND ---
playground/
!playground/**/src/
!playground/**/Cargo.toml
!playground/**/.gitkeep
playground/target/

# --- COVERAGE ---
tarpaulin-report.html
*.gcda
*.gcno
